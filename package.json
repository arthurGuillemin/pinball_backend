{
  "name": "pinball_backend",
  "version": "1.0.0",
  "description": "Backend du projet pinball , websocket pour la communication esp32 > playglass , playglass > dmd > backglass et api pour la gestion des high scores",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "bridge": "nodemon src/bridge/bridge.js",
    "test": "vitest run",
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "prepare": "husky",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arthurGuillemin/pinball_backend.git"
  },
  "keywords": [
    "node",
    "websocket",
    "api"
  ],
  "author": "Arthur Guillemin",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/arthurGuillemin/pinball_backend/issues"
  },
  "homepage": "https://github.com/arthurGuillemin/pinball_backend#readme",
  "dependencies": {
    "@supabase/supabase-js": "^2.96.0",
    "applicationinsights": "^3.14.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "mqtt": "^5.15.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "nodemon": "^3.1.11",
    "prettier": "^3.8.3",
    "semantic-release": "^25.0.3",
    "supertest": "^7.2.2",
    "vitest": "^4.0.18"
  }
}
